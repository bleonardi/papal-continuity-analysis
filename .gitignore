# Raw corpus text files — too large for GitHub
data/raw/

# Quarto intermediates
*.quarto_ipynb
.quarto/
__pycache__/
*.pyc

# macOS
.DS_Store
data/*.html

/.quarto/
**/*.quarto_ipynb

# rag-chat.qmd is a Shiny doc rendered directly (not part of docs/) —
# local `quarto render rag-chat.qmd` / `quarto serve` output
/rag-chat.html
/rag-chat_files/
/rag-chat.knit.md
/manifest.json

# Never commit secrets — rag/deploy.R writes GOOGLE_API_KEY into a
# .Renviron in an isolated /tmp staging dir, not here, but this is a
# safety net in case one's ever created at the repo root for local dev.
.Renviron
